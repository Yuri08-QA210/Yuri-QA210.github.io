<section class="section" id="pwn">
  <h2><i class="bi bi-terminal"></i> 5. Pwn Script</h2>
  <h3 id="pwn-full">Full Exploit</h3>
  <div class="code-block">
    <div class="code-header"><span class="lang-tag">python</span><button class="copy-btn" onclick="copyCode(this)">Copy</button></div>
    <pre><code class="language-python">#!/usr/bin/env python3
